@model IEnumerable<ParolGenerator.Models.AsciiChar>

@{
    ViewData["Title"] = "ASCII jadvali";
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <div class="container mt-5">
        <h1 class="text-center mb-4">📋 ASCII jadvali (32-126)</h1>

        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ASCII qiymati</th>
                                    <th>Belgi</th>
                                    <th>Turkum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><code>@item.Value</code></td>
                                        <td><code>'@item.Char'</code></td>
                                        <td>
                                            @if (item.Category == "Raqam")
                                            {
                                                <span class="badge bg-primary">@item.Category</span>
                                            }
                                            else if (item.Category == "Katta harf")
                                            {
                                                <span class="badge bg-success">@item.Category</span>
                                            }
                                            else if (item.Category == "Kichik harf")
                                            {
                                                <span class="badge bg-info">@item.Category</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">@item.Category</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <a asp-action="Index" class="btn btn-primary">⬅ Ortga</a>
        </div>
    </div>
</body>
</html>